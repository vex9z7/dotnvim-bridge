#!/usr/bin/env bash
set -euo pipefail

# Smoke-test the client/container side of the Neovim MCP endpoint.
# Required:
#   NVIM_ADDRESS=host:port
#
# This validates TCP reachability and that `uvx nvim-mcp` can start.
# Full validation still requires a Codex MCP tool call, e.g. get_state_brief.

if [[ -z "${NVIM_ADDRESS:-}" ]]; then
  echo "error: NVIM_ADDRESS is not set" >&2
  echo "example: NVIM_ADDRESS=vex9z7.com:16667 $0" >&2
  exit 2
fi

host="${NVIM_ADDRESS%:*}"
port="${NVIM_ADDRESS##*:}"

if [[ -z "$host" || -z "$port" || "$host" == "$NVIM_ADDRESS" ]]; then
  echo "error: NVIM_ADDRESS must be host:port, got: $NVIM_ADDRESS" >&2
  exit 2
fi

echo "[1/3] endpoint: $NVIM_ADDRESS"

echo "[2/3] testing TCP connection..."
python3 - "$host" "$port" <<'PY'
import socket
import sys
host = sys.argv[1]
port = int(sys.argv[2])
s = socket.create_connection((host, port), timeout=3)
s.close()
print(f"connected to {host}:{port}")
PY

echo "[3/3] checking uvx and nvim-mcp startup..."
command -v uvx >/dev/null
uvx --version

set +e
timeout 3s env NVIM_ADDRESS="$NVIM_ADDRESS" uvx nvim-mcp >/tmp/nvim-mcp-smoke.out 2>/tmp/nvim-mcp-smoke.err
code=$?
set -e

if [[ "$code" == "124" ]]; then
  echo "nvim-mcp started and waited for MCP stdio as expected"
  echo "endpoint smoke test passed"
  exit 0
fi

if [[ "$code" == "0" ]]; then
  echo "nvim-mcp exited cleanly during smoke test"
  echo "note: this only proves the process can start; full validation requires an MCP tool call"
  echo "endpoint smoke test partially passed"
  exit 0
fi

echo "error: nvim-mcp smoke test failed with exit code $code" >&2
echo "--- stdout ---" >&2
cat /tmp/nvim-mcp-smoke.out >&2 || true
echo "--- stderr ---" >&2
cat /tmp/nvim-mcp-smoke.err >&2 || true
exit "$code"
